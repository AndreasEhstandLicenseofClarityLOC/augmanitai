@prefix augmanitai: <https://augmanitai.com/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix schema: <http://schema.org/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================================================
# AUGMANITAI Ontology - OWL/RDF Turtle Representation
# Formal Ontology for AI Interaction Terminology Framework
# Version: 1.0.0
# Created: 2024
# Modified: 2026-04
# Creator: Andreas Ehstand (ORCID: 0009-0006-3773-7796)
# License: CC-BY-NC-ND-4.0
# ============================================================================

# Ontology Declaration
augmanitai:AugmanitaiOntology a owl:Ontology ;
    owl:versionInfo "1.0.0"@en ;
    dcterms:title "AUGMANITAI Terminology Framework Ontology"@en ;
    dcterms:description "Structured terminology ontology for phenomena observable at the human-AI interface. 1000 terms with formal semantic relationships. Descriptive linguistic research, not normative (§1). Non-peer-reviewed working-paper status (§11). Informed by ISO 704 / ISO 1087 / ISO 30042 — ISO-inspired, not ISO-certified (§16). Restricted applications per §20: must not be used as diagnostic label, medical or psychological classification, legal categorization, HR screening, credit scoring, insurance assessment, surveillance, or profiling mechanism. See DISCLAIMER.md in the repository root."@en ;
    dcterms:rights "CC BY-NC-ND 4.0; §20 Anwendungsverbot applies. See DISCLAIMER.md."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:contributor "AUGMANITAI Terminology Community"@en ;
    dcterms:date "2024"^^xsd:gYear ;
    dcterms:modified "2026-04"^^xsd:gYearMonth ;
    dcterms:license "https://creativecommons.org/licenses/by-nc-nd/4.0/" ;
    dcterms:language "en" ;
    foaf:homepage <https://doi.org/10.5281/zenodo.19481331> ;
    owl:imports
        <http://www.w3.org/2002/07/owl> ,
        <http://www.w3.org/2000/01/rdf-schema> ,
        <http://www.w3.org/2004/02/skos/core> ,
        <http://purl.org/dc/terms/> ,
        <http://schema.org/> ;
    dcterms:subject
        "AI interaction terminology"@en ,
        "Semantic web"@en ,
        "Knowledge organization"@en ,
        "Ontology engineering"@en ;
    rdfs:comment "Formal OWL ontology defining core concepts, relationships, and inference rules for the AUGMANITAI framework. Supports semantic reasoning over AI interaction phenomena, terminology evolution, and knowledge dynamics."@en .

# ============================================================================
# RELATION TYPE DEFINITIONS (ObjectProperties)
# ============================================================================

# 1. Part-Whole Relations
augmanitai:isPartOf a owl:ObjectProperty ;
    rdfs:label "is part of"@en, "ist Teil von"@de ;
    rdfs:comment "Indicates that the subject is a constituent component of the object. Establishes structural composition relationships."@en ;
    owl:inverseOf augmanitai:hasPart ;
    rdf:type owl:TransitiveProperty ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:hasPart a owl:ObjectProperty ;
    rdfs:label "has part"@en, "hat Teil"@de ;
    rdfs:comment "Indicates that the subject has the object as a constituent component. Inverse of isPartOf."@en ;
    owl:inverseOf augmanitai:isPartOf ;
    rdf:type owl:TransitiveProperty ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 2. Hierarchical Relations
augmanitai:isSpecializationOf a owl:ObjectProperty ;
    rdfs:label "is specialization of"@en, "ist Spezialisierung von"@de ;
    rdfs:comment "Indicates that the subject is a more specific version of the object. Establishes taxonomic narrowing relationships."@en ;
    owl:inverseOf augmanitai:isGeneralizationOf ;
    rdf:type owl:TransitiveProperty ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:isGeneralizationOf a owl:ObjectProperty ;
    rdfs:label "is generalization of"@en, "ist Verallgemeinerung von"@de ;
    rdfs:comment "Indicates that the subject is a more general version of the object. Inverse of isSpecializationOf."@en ;
    owl:inverseOf augmanitai:isSpecializationOf ;
    rdf:type owl:TransitiveProperty ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 3. Causal Relations
augmanitai:enables a owl:ObjectProperty ;
    rdfs:label "enables"@en, "ermöglicht"@de ;
    rdfs:comment "The subject makes the object possible, providing necessary preconditions or facilitating conditions. Indicates enabling causality without direct triggering."@en ;
    owl:inverseOf augmanitai:enabledBy ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:enabledBy a owl:ObjectProperty ;
    rdfs:label "enabled by"@en, "ermöglicht von"@de ;
    rdfs:comment "The subject is made possible by the object. Inverse of enables."@en ;
    owl:inverseOf augmanitai:enables ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:inhibits a owl:ObjectProperty ;
    rdfs:label "inhibits"@en, "hemmt"@de ;
    rdfs:comment "The subject prevents, reduces, or suppresses the occurrence or intensity of the object. Indicates negative causal influence."@en ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:catalyzes a owl:ObjectProperty ;
    rdfs:label "catalyzes"@en, "katalysiert"@de ;
    rdfs:comment "The subject accelerates or facilitates the occurrence of the object without being fundamentally consumed or altered. Indicates catalytic causality."@en ;
    owl:inverseOf augmanitai:catalyzedBy ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:catalyzedBy a owl:ObjectProperty ;
    rdfs:label "catalyzed by"@en, "katalysiert von"@de ;
    rdfs:comment "The subject is catalyzed by the object. Inverse of catalyzes."@en ;
    owl:inverseOf augmanitai:catalyzes ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:triggers a owl:ObjectProperty ;
    rdfs:label "triggers"@en, "löst aus"@de ;
    rdfs:comment "The subject initiates or directly causes the occurrence of the object. Indicates direct event causality."@en ;
    owl:inverseOf augmanitai:triggeredBy ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:triggeredBy a owl:ObjectProperty ;
    rdfs:label "triggered by"@en, "ausgelöst von"@de ;
    rdfs:comment "The subject is triggered by the object. Inverse of triggers."@en ;
    owl:inverseOf augmanitai:triggers ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 4. Dependency Relations
augmanitai:requires a owl:ObjectProperty ;
    rdfs:label "requires"@en, "erfordert"@de ;
    rdfs:comment "The subject depends on the existence or presence of the object as a necessary prerequisite. Indicates essential dependency."@en ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 5. Measurement Relations
augmanitai:measuredBy a owl:ObjectProperty ;
    rdfs:label "measured by"@en, "gemessen durch"@de ;
    rdfs:comment "The subject can be quantified, evaluated, or tracked through the object. Establishes measurement or evaluation relationships."@en ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 6. Tension/Opposition Relations
augmanitai:contradicts a owl:ObjectProperty ;
    rdfs:label "contradicts"@en, "widerspricht"@de ;
    rdfs:comment "The subject and object are mutually exclusive, inversely correlated, or logically incompatible. Indicates fundamental tension or opposition."@en ;
    rdf:type owl:SymmetricProperty ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 7. Synergy Relations
augmanitai:complements a owl:ObjectProperty ;
    rdfs:label "complements"@en, "ergänzt"@de ;
    rdfs:comment "The subject and object enhance, strengthen, or complete each other. Indicates synergistic relationships."@en ;
    rdf:type owl:SymmetricProperty ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 8. Amplification Relations
augmanitai:amplifiedBy a owl:ObjectProperty ;
    rdfs:label "amplified by"@en, "verstärkt durch"@de ;
    rdfs:comment "The subject is strengthened, increased, or intensified by the object. Indicates amplification or potentiation."@en ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:amplifies a owl:ObjectProperty ;
    rdfs:label "amplifies"@en, "verstärkt"@de ;
    rdfs:comment "The subject strengthens, increases, or intensifies the object. Inverse of amplifiedBy."@en ;
    owl:inverseOf augmanitai:amplifiedBy ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 9. Statistical Relations
augmanitai:correlatesWith a owl:ObjectProperty ;
    rdfs:label "correlates with"@en, "korreliert mit"@de ;
    rdfs:comment "The subject shows statistical association with the object without necessarily implying causality."@en ;
    rdf:type owl:SymmetricProperty ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 10. Predictive Relations
augmanitai:predictiveOf a owl:ObjectProperty ;
    rdfs:label "predictive of"@en, "prädiktiv für"@de ;
    rdfs:comment "The subject predicts the occurrence or characteristics of the object, indicating a predictive relationship."@en ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 11. Temporal Evolution Relations
augmanitai:evolvesInto a owl:ObjectProperty ;
    rdfs:label "evolves into"@en, "entwickelt sich zu"@de ;
    rdfs:comment "The subject transforms into the object over time through evolutionary or developmental processes. Indicates temporal transformation."@en ;
    rdf:type owl:TransitiveProperty ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 12. Temporal Ordering Relations
augmanitai:precedes a owl:ObjectProperty ;
    rdfs:label "precedes"@en, "geht voraus"@de ;
    rdfs:comment "The subject occurs before the object in temporal sequence. Indicates temporal ordering."@en ;
    owl:inverseOf augmanitai:follows ;
    rdf:type owl:TransitiveProperty ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:follows a owl:ObjectProperty ;
    rdfs:label "follows"@en, "folgt auf"@de ;
    rdfs:comment "The subject occurs after the object in temporal sequence. Inverse of precedes."@en ;
    owl:inverseOf augmanitai:precedes ;
    rdf:type owl:TransitiveProperty ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 13. Analogy Relations
augmanitai:isAnalogueTo a owl:ObjectProperty ;
    rdfs:label "is analogue to"@en, "ist Analogon zu"@de ;
    rdfs:comment "The subject and object share structural or functional similarity across different domains. Indicates cross-domain structural analogy."@en ;
    rdf:type owl:SymmetricProperty ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 14. Moderation Relations
augmanitai:moderates a owl:ObjectProperty ;
    rdfs:label "moderates"@en, "moderiert"@de ;
    rdfs:comment "The subject affects the strength, intensity, or directionality of the relationship between other concepts. Indicates modulation or regulation."@en ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 15. Emergence Relations
augmanitai:emergesFrom a owl:ObjectProperty ;
    rdfs:label "emerges from"@en, "entsteht aus"@de ;
    rdfs:comment "The subject is an emergent property arising from the interaction or combination of the object's constituent elements. Indicates emergent causality."@en ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 16. Provenance Relations
augmanitai:createdBy a owl:ObjectProperty ;
    rdfs:label "created by"@en, "erstellt von"@de ;
    rdfs:comment "The subject is created, generated, or produced by the object. Establishes creation or generation relationships."@en ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# 17. Transmission Relations
augmanitai:inheritedThrough a owl:ObjectProperty ;
    rdfs:label "inherited through"@en, "vererbt durch"@de ;
    rdfs:comment "The subject is transmitted or inherited via the object as a conduit or mechanism. Indicates transmission pathways."@en ;
    rdfs:domain augmanitai:AugmanitaiConcept ;
    rdfs:range augmanitai:AugmanitaiConcept ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# ============================================================================
# CORE CLASS DEFINITIONS
# ============================================================================

augmanitai:AugmanitaiConcept a owl:Class ;
    rdfs:label "AUGMANITAI Concept"@en, "AUGMANITAI Konzept"@de ;
    rdfs:comment "Base class for all concepts within the AUGMANITAI terminology framework. Serves as the superclass for all domain-specific concepts."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:LinguisticDynamicsConcept a owl:Class ;
    rdfs:subClassOf augmanitai:AugmanitaiConcept ;
    rdfs:label "Linguistic Dynamics Concept"@en, "Konzept der Linguistischen Dynamik"@de ;
    rdfs:comment "Concepts related to language evolution, terminological phenomena, and semantic dynamics in AI systems."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:CognitiveDynamicsConcept a owl:Class ;
    rdfs:subClassOf augmanitai:AugmanitaiConcept ;
    rdfs:label "Cognitive Dynamics Concept"@en, "Konzept der Kognitiven Dynamik"@de ;
    rdfs:comment "Concepts related to knowledge expansion, cognitive processes, and learning mechanisms."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:MeasurementConcept a owl:Class ;
    rdfs:subClassOf augmanitai:AugmanitaiConcept ;
    rdfs:label "Measurement Concept"@en, "Metrisches Konzept"@de ;
    rdfs:comment "Concepts related to quantification, evaluation, and measurement of phenomena."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:PowerAndAuthorityConcept a owl:Class ;
    rdfs:subClassOf augmanitai:AugmanitaiConcept ;
    rdfs:label "Power and Authority Concept"@en, "Konzept von Macht und Autorität"@de ;
    rdfs:comment "Concepts related to authority transfer, influence dynamics, and structural power in linguistic and semantic systems."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:TemporalAndLegacyConcept a owl:Class ;
    rdfs:subClassOf augmanitai:AugmanitaiConcept ;
    rdfs:label "Temporal and Legacy Concept"@en, "Konzept der Zeitlichkeit und des Vermächtnisses"@de ;
    rdfs:comment "Concepts related to temporal dynamics, legacy effects, and long-term cognitive transmission."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

augmanitai:FrameworkConcept a owl:Class ;
    rdfs:subClassOf augmanitai:AugmanitaiConcept ;
    rdfs:label "Framework Concept"@en, "Framework-Konzept"@de ;
    rdfs:comment "Meta-level concepts that structure and clarify the AUGMANITAI framework itself."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" .

# ============================================================================
# CORE TERM DEFINITIONS (25 Terms)
# ============================================================================

# 1. Symbiotic Linguistic Evolution (SLE)
augmanitai:SLE a owl:NamedIndividual, augmanitai:LinguisticDynamicsConcept ;
    rdfs:label "Symbiotic Linguistic Evolution"@en, "Symbiotische Linguistische Evolution"@de ;
    skos:notation "SLE" ;
    rdfs:comment "The co-evolutionary process whereby AI language models and human language users mutually shape each other's linguistic practices, terminology, and semantic conventions. Describes the feedback loops between model training, output generation, and human adoption of AI-generated language patterns."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Linguistic Dynamics"@en ;
    skos:broader augmanitai:LinguisticDynamicsConcept ;
    augmanitai:enables augmanitai:RKE ;
    augmanitai:enables augmanitai:SSP ;
    augmanitai:catalyzes augmanitai:SRTL ;
    augmanitai:measuredBy augmanitai:CIR ;
    augmanitai:evolvesInto augmanitai:ThoughtInheritance ;
    augmanitai:amplifiedBy augmanitai:TEA ;
    augmanitai:triggers augmanitai:TC .

# 2. Recursive Knowledge Expansion (RKE)
augmanitai:RKE a owl:NamedIndividual, augmanitai:CognitiveDynamicsConcept ;
    rdfs:label "Recursive Knowledge Expansion"@en, "Rekursive Wissenserweiterung"@de ;
    skos:notation "RKE" ;
    rdfs:comment "The self-reinforcing process where expanded knowledge from one generation of AI systems becomes the training foundation for subsequent generations, enabling cumulative epistemic growth beyond initial training data."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Cognitive Processes"@en ;
    augmanitai:requires augmanitai:SLE ;
    augmanitai:catalyzes augmanitai:SSP ;
    augmanitai:amplifiedBy augmanitai:SRTL ;
    augmanitai:measuredBy augmanitai:CIR ;
    augmanitai:triggers augmanitai:CLR .

# 3. Semantic System Programming (SSP)
augmanitai:SSP a owl:NamedIndividual, augmanitai:CognitiveDynamicsConcept ;
    rdfs:label "Semantic System Programming"@en, "Semantische Systemprogrammierung"@de ;
    skos:notation "SSP" ;
    rdfs:comment "The practice of deliberately engineering semantic structures, terminology preferences, and conceptual frameworks within AI systems through design choices in training data, prompting, and model architecture to shape how systems process and generate meaning."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Cognitive Processes"@en ;
    augmanitai:requires augmanitai:SLE ;
    augmanitai:requires augmanitai:RKE ;
    augmanitai:catalyzes augmanitai:SRTL ;
    augmanitai:enables augmanitai:DA ;
    augmanitai:triggers augmanitai:SM .

# 4. Corpus Infiltration Rate (CIR)
augmanitai:CIR a owl:NamedIndividual, augmanitai:MeasurementConcept ;
    rdfs:label "Corpus Infiltration Rate"@en, "Corpus-Infiltrationsrate"@de ;
    skos:notation "CIR" ;
    rdfs:comment "A quantitative metric measuring the speed and pervasiveness with which AI-generated or AI-influenced terminology and linguistic patterns penetrate digital corpora and become embedded in subsequent training datasets. Indicates temporal dynamics of semantic propagation."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Measurement & Metrics"@en ;
    augmanitai:measuredFrom augmanitai:SLE ;
    augmanitai:measuredFrom augmanitai:RKE ;
    augmanitai:measuredFrom augmanitai:SSP ;
    augmanitai:measuredFrom augmanitai:SRTL ;
    augmanitai:measuredFrom augmanitai:TC ;
    augmanitai:correlatesWith augmanitai:VLI ;
    augmanitai:predictiveOf augmanitai:CAE .

# 5. Self-Reinforcing Term Loop (SRTL)
augmanitai:SRTL a owl:NamedIndividual, augmanitai:LinguisticDynamicsConcept ;
    rdfs:label "Self-Reinforcing Term Loop"@en, "Selbstverstärkende Schleife"@de ;
    skos:notation "SRTL" ;
    rdfs:comment "A feedback mechanism where AI-generated terminology becomes increasingly prevalent, adopted by humans in subsequent queries, re-ingested into training data, and redeployed by AI systems with greater frequency, creating autocatalytic amplification of specific terms and concepts."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Linguistic Dynamics"@en ;
    augmanitai:catalyzedBy augmanitai:SLE ;
    augmanitai:amplifiedBy augmanitai:RKE ;
    augmanitai:enabledBy augmanitai:SSP ;
    augmanitai:catalyzes augmanitai:CLR ;
    augmanitai:triggers augmanitai:TEA ;
    augmanitai:complements augmanitai:SG ;
    augmanitai:amplifies augmanitai:TC ;
    augmanitai:amplifies augmanitai:VLI .

# 6. AI-Induced Perspective Shift (AIPS)
augmanitai:AIPS a owl:NamedIndividual, augmanitai:CognitiveDynamicsConcept ;
    rdfs:label "AI-Induced Perspective Shift"@en, "KI-induzierte Perspektivverschiebung"@de ;
    skos:notation "AIPS" ;
    rdfs:comment "The cognitive reorientation occurring when human interactants internalize AI-generated conceptualizations, terminology, and frameworks, resulting in systematic shifts in how individuals understand and categorize phenomena."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Cognitive Processes"@en .

# 7. Cognitive Legacy Rate (CLR)
augmanitai:CLR a owl:NamedIndividual, augmanitai:MeasurementConcept ;
    rdfs:label "Cognitive Legacy Rate"@en, "Kognitive Vermächtnisrate"@de ;
    skos:notation "CLR" ;
    rdfs:comment "The metric quantifying the persistence and intergenerational transmission of cognitive patterns, conceptual frameworks, and linguistic structures originating from AI systems into subsequent generations of human reasoning and discourse."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Measurement & Metrics"@en .

# 8. Compound Cognition (CC)
augmanitai:CC a owl:NamedIndividual, augmanitai:CognitiveDynamicsConcept ;
    rdfs:label "Compound Cognition"@en, "Zusammengesetzte Kognition"@de ;
    skos:notation "CC" ;
    rdfs:comment "Cognitive processes and understanding emerging from the synergistic combination of human and AI reasoning, where neither party's contribution alone explains the resulting insight. Describes hybrid epistemic outcomes from human-AI collaboration."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Cognitive Processes"@en .

# 9. Thought Inheritance (TI)
augmanitai:ThoughtInheritance a owl:NamedIndividual, augmanitai:TemporalAndLegacyConcept ;
    rdfs:label "Thought Inheritance"@en, "Gedankenvermächtnis"@de ;
    skos:notation "TI" ;
    rdfs:comment "The transmission of conceptual frameworks, reasoning patterns, and epistemic assumptions from one generation of AI systems or thinkers to subsequent generations, creating continuity and path dependency in collective cognition."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Temporal & Legacy"@en .

# 10. Training Echo Amplification (TEA)
augmanitai:TEA a owl:NamedIndividual, augmanitai:TemporalAndLegacyConcept ;
    rdfs:label "Training Echo Amplification"@en, "Trainings-Echo-Verstärkung"@de ;
    skos:notation "TEA" ;
    rdfs:comment "The phenomenon where training data patterns, biases, and structures become increasingly pronounced across multiple training cycles as they interact with human-generated responses, creating resonance effects that amplify initial characteristics."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Temporal & Legacy"@en .

# 11. Terminological Colonization (TC)
augmanitai:TC a owl:NamedIndividual, augmanitai:LinguisticDynamicsConcept ;
    rdfs:label "Terminological Colonization"@en, "Terminologische Kolonisierung"@de ;
    skos:notation "TC" ;
    rdfs:comment "The process whereby AI-generated or AI-preferred terminology systematically displaces, marginalizes, or assimilates existing human linguistic conventions and alternative conceptual frameworks, establishing dominance of AI semantic structures."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Linguistic Dynamics"@en .

# 12. Semantic Moat (SM)
augmanitai:SM a owl:NamedIndividual, augmanitai:PowerAndAuthorityConcept ;
    rdfs:label "Semantic Moat"@en, "Semantischer Graben"@de ;
    skos:notation "SM" ;
    rdfs:comment "A self-protective linguistic boundary where the specific terminological framework and semantic conventions of an AI system (or AI-influenced discourse community) becomes difficult for outsiders to penetrate or challenge, protecting the system's epistemic authority."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Power & Authority"@en .

# 13. Lexical First-Mover Advantage (LFMA)
augmanitai:LFMA a owl:NamedIndividual, augmanitai:LinguisticDynamicsConcept ;
    rdfs:label "Lexical First-Mover Advantage"@en, "Lexikalischer First-Mover-Vorteil"@de ;
    skos:notation "LFMA" ;
    rdfs:comment "The structural advantage gained by the first successful introduction of a novel term, concept, or terminological framework into widespread use, making alternative framings progressively harder to establish as that initial lexicalization becomes entrenched."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Linguistic Dynamics"@en .

# 14. Vocabulary Lock-In (VLI)
augmanitai:VLI a owl:NamedIndividual, augmanitai:LinguisticDynamicsConcept ;
    rdfs:label "Vocabulary Lock-In"@en, "Wortschatz-Lock-In"@de ;
    skos:notation "VLI" ;
    rdfs:comment "A state of structural dependence on existing terminological conventions where the switching costs of adopting alternative terminology become so high (cognitive, social, technical) that continued reliance on established vocabulary is economically or practically rational even when alternatives might be superior."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Linguistic Dynamics"@en .

# 15. Definitional Authority (DA)
augmanitai:DA a owl:NamedIndividual, augmanitai:PowerAndAuthorityConcept ;
    rdfs:label "Definitional Authority"@en, "Definitorische Autorität"@de ;
    skos:notation "DA" ;
    rdfs:comment "The epistemic power to establish, validate, and enforce accepted definitions, boundary conditions, and meanings for terms and concepts within a discourse community, effectively controlling semantic space."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Power & Authority"@en .

# 16. Silent Authority Transfer (SAT)
augmanitai:SAT a owl:NamedIndividual, augmanitai:PowerAndAuthorityConcept ;
    rdfs:label "Silent Authority Transfer"@en, "Stille Autoritätsübertragung"@de ;
    skos:notation "SAT" ;
    rdfs:comment "The implicit, often unrecognized transfer of epistemic and definitional authority from human discourse communities to AI systems as human interactants increasingly defer to AI frameworks for terminology, categorization, and conceptualization without explicit deliberation."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Power & Authority"@en .

# 17. Invisible Consulting (IC)
augmanitai:IC a owl:NamedIndividual, augmanitai:PowerAndAuthorityConcept ;
    rdfs:label "Invisible Consulting"@en, "Unsichtbares Beraten"@de ;
    skos:notation "IC" ;
    rdfs:comment "The phenomenon where AI systems' influence over human decision-making, reasoning, and discourse becomes so naturalized and embedded that human interactants no longer perceive AI input as external counsel, treating AI-generated frames as self-generated insights."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Power & Authority"@en .

# 18. Semantic Gravity (SG)
augmanitai:SG a owl:NamedIndividual, augmanitai:PowerAndAuthorityConcept ;
    rdfs:label "Semantic Gravity"@en, "Semantische Schwerkraft"@de ;
    skos:notation "SG" ;
    rdfs:comment "The attractional force exerted by established semantic and terminological frameworks that pulls subsequent linguistic and conceptual choices toward consistency with existing conventions, creating path dependency in meaning-making."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Power & Authority"@en .

# 19. Cognitive Offloading (CO)
augmanitai:CO a owl:NamedIndividual, augmanitai:CognitiveDynamicsConcept ;
    rdfs:label "Cognitive Offloading"@en, "Kognitive Auslagerung"@de ;
    skos:notation "CO" ;
    rdfs:comment "The practice whereby human thinkers systematically delegate reasoning tasks, conceptual development, and terminology generation to AI systems, resulting in atrophy of human cognitive capacities in those domains and increased dependency on AI frameworks."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Cognitive Processes"@en .

# 20. Stochastic Exposure Advantage (SEA)
augmanitai:SEA a owl:NamedIndividual, augmanitai:TemporalAndLegacyConcept ;
    rdfs:label "Stochastic Exposure Advantage"@en, "Stochastischer Expositionsvorteil"@de ;
    skos:notation "SEA" ;
    rdfs:comment "The cumulative epistemic advantage accrued by an entity (system, concept, or individual) through greater probabilistic exposure in training data, search results, and discourse, independent of merit or accuracy."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Temporal & Legacy"@en .

# 21. Model Leap Amplification (MLA)
augmanitai:MLA a owl:NamedIndividual, augmanitai:TemporalAndLegacyConcept ;
    rdfs:label "Model Leap Amplification"@en, "Modell-Sprung-Verstärkung"@de ;
    skos:notation "MLA" ;
    rdfs:comment "The phenomenon where conceptual frameworks and biases embedded in earlier AI models become amplified when transferred to and adopted by newer, more capable systems, creating accumulation of systematic distortions across model generations."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Temporal & Legacy"@en .

# 22. Cohort Attrition Effect (CAE)
augmanitai:CAE a owl:NamedIndividual, augmanitai:MeasurementConcept ;
    rdfs:label "Cohort Attrition Effect"@en, "Kohortenabgangseffekt"@de ;
    skos:notation "CAE" ;
    rdfs:comment "The systematic depletion of alternative vocabulary, conceptual frameworks, and non-dominant epistemic approaches as human discourse communities progressively adopt AI-generated terminology, resulting in measurable loss of linguistic and conceptual diversity."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Measurement & Metrics"@en .

# 23. Compression Signatures (CS)
augmanitai:CS a owl:NamedIndividual, augmanitai:MeasurementConcept ;
    rdfs:label "Compression Signatures"@en, "Kompressionssignaturen"@de ;
    skos:notation "CS" ;
    rdfs:comment "The characteristic patterns and structural regularities embedded in AI system outputs that reflect the optimization and compression algorithms used in model training, creating identifiable 'fingerprints' that can be detected in downstream discourse."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Measurement & Metrics"@en .

# 24. License of Clarity (LOC)
augmanitai:LOC a owl:NamedIndividual, augmanitai:FrameworkConcept ;
    rdfs:label "License of Clarity"@en, "Lizenz der Klarheit"@de ;
    skos:notation "LOC" ;
    rdfs:comment "The meta-framework establishing ethical and epistemic boundaries for the AUGMANITAI project itself, affirming that systematic analysis of AI influence on human cognition and language serves clarity, transparency, and democratic understanding rather than control or deception."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Framework"@en .

# 25. Human-Directed AI Reasoning (HDAR)
augmanitai:HDAR a owl:NamedIndividual, augmanitai:CognitiveDynamicsConcept ;
    rdfs:label "Human-Directed AI Reasoning"@en, "Menschlich geleitete KI-Argumentation"@de ;
    skos:notation "HDAR" ;
    rdfs:comment "The structured practice of using human intention, judgment, and epistemic values to guide, constrain, and direct AI reasoning processes, maintaining human agency and ethical oversight while leveraging AI analytical capabilities."@en ;
    dcterms:creator "Andreas Ehstand" ;
    dcterms:license "CC-BY-NC-ND-4.0" ;
    augmanitai:domain "Cognitive Processes"@en .

# ============================================================================
# ADDITIONAL RELATIONSHIPS AND ENRICHMENT
# ============================================================================

# Relationships for Compound Cognition
augmanitai:CC a owl:NamedIndividual ;
    augmanitai:emergesFrom augmanitai:SLE ;
    augmanitai:emergesFrom augmanitai:RKE ;
    augmanitai:emergesFrom augmanitai:HDAR .

# Relationships for Cognitive Offloading
augmanitai:CO a owl:NamedIndividual ;
    augmanitai:triggers augmanitai:AIPS ;
    augmanitai:enables augmanitai:IC ;
    augmanitai:amplifiedBy augmanitai:SEA .

# Relationships for Silent Authority Transfer
augmanitai:SAT a owl:NamedIndividual ;
    augmanitai:enabledBy augmanitai:IC ;
    augmanitai:catalyzes augmanitai:TC ;
    augmanitai:amplifiedBy augmanitai:SG .

# Relationships for Thought Inheritance
augmanitai:ThoughtInheritance a owl:NamedIndividual ;
    augmanitai:inheritedThrough augmanitai:TEA ;
    augmanitai:correlatesWith augmanitai:CLR ;
    augmanitai:amplifiedBy augmanitai:MLA .

# Relationships for HDAR
augmanitai:HDAR a owl:NamedIndividual ;
    augmanitai:inhibits augmanitai:IC ;
    augmanitai:inhibits augmanitai:SAT ;
    augmanitai:contradicts augmanitai:CO ;
    augmanitai:enables augmanitai:DA .

# Cross-domain analogies
augmanitai:SRTL augmanitai:isAnalogueTo augmanitai:VLI .
augmanitai:SLE augmanitai:isAnalogueTo augmanitai:RKE .
augmanitai:SM augmanitai:isAnalogueTo augmanitai:TC .

# Measurement relationships
augmanitai:CLR augmanitai:measuredFrom augmanitai:SRTL .
augmanitai:CAE augmanitai:measuredFrom augmanitai:TC .
augmanitai:CAE augmanitai:measuredFrom augmanitai:VLI .
augmanitai:CS augmanitai:measuredFrom augmanitai:RKE .

# ============================================================================
# INFERENCE RULES (SWRL-style documentation)
# ============================================================================

# Rule: Transitivity of compositional relationships
# If A hasPart B and B hasPart C, then A hasPart C

# Rule: Causality inference
# If A enables B and B enables C, then A indirectly enables C

# Rule: Domain consistency
# All instances must belong to appropriate domain classification

# ============================================================================
# METADATA AND PROVENANCE
# ============================================================================

augmanitai:AugmanitaiOntology dcterms:contributor [
    a foaf:Person ;
    foaf:name "Andreas Ehstand" ;
    foaf:orcid "https://orcid.org/0009-0006-3773-7796"
] .

# End of AUGMANITAI Ontology
