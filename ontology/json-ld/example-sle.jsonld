  "id": "https://augmanitai.org/term/SLE",
  "type": ["skos:Concept", "augont:Term"],

  "term": "Symbiotic Linguistic Evolution",
  "abbreviation": "SLE",

  "definition": {
    "en": "The process by which human language and AI-generated language patterns co-evolve through repeated interaction, creating emergent linguistic features not present in either party's original communication patterns."
  },

  "definitions": {
    "en": "The process by which human language and AI-generated language patterns co-evolve through repeated interaction, creating emergent linguistic features not present in either party's original communication patterns.",
    "de": "Der Prozess, durch den sich menschliche Sprache und KI-generierte Sprachmuster durch wiederholte Interaktion gemeinsam entwickeln und emergente sprachliche Merkmale schaffen, die in den ursprünglichen Kommunikationsmustern beider Parteien nicht vorhanden sind."
  },

  "domain": "linguistic_dynamics",

  "iso704Characteristics": [
    "Co-evolutionary process between human and machine language",
    "Emergent linguistic features result from repeated interaction",
    "Changes present in both communicating parties"
  ],

  "examples": [
    "Users adopt AI-suggested phrasings in subsequent conversations",
    "Anthropomorphic language patterns emerge in human prompts",
    "Formal registers from AI outputs influence human writing style"
  ],

  "prefLabel": {
    "en": "Symbiotic Linguistic Evolution"
  },

