@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================================================
# AUGMANITAI OntoLex-Lemon Lexical Repository
# Multilingual Lexical Encoding and Decomposition for AI Terminology
# Creator: Andreas Ehstand (ORCID: 0009-0006-3773-7796)
# License: CC BY-NC-ND 4.0
# Informed by ISO 1087 (Terminology vocabulary) and ISO 30042 (TBX) —
# ISO-inspired, not ISO-certified (§16 of DISCLAIMER.md).
# ============================================================================

# Lexicon Definition
aug:AugmanitaiLexicon a ontolex:Lexicon ;
    rdfs:label "AUGMANITAI Lexicon"@en ;
    dct:description "Multilingual lexical resource for terminology of human-AI interaction phenomena in English, German, Mandarin Chinese, Hindi, and Arabic. Descriptive linguistic research, not normative (§1). Non-peer-reviewed working-paper (§11). Informed by ISO 1087 / ISO 30042 — ISO-inspired, not ISO-certified (§16). Restricted applications per §20 (see DISCLAIMER.md in repository root): must not be used as diagnostic label, medical/psychological classification, legal categorization, HR screening, credit scoring, insurance assessment, surveillance, or profiling mechanism."@en ;
    dct:language "en", "de", "zh", "hi", "ar" ;
    dct:creator "Andreas Ehstand" ;
    dct:date "2026-04-10"^^xsd:date ;
    dct:license "https://creativecommons.org/licenses/by-nc-nd/4.0/" ;
    dct:rights "CC BY-NC-ND 4.0; §20 Anwendungsverbot applies. See DISCLAIMER.md."@en .

# ============================================================================
# TERM 1: SLE - Symbiotic Linguistic Evolution
# ============================================================================

aug:SLE a ontolex:LexicalEntry ;
    rdfs:label "SLE"@en ;
    dct:created "2024"^^xsd:gYear ;
    ontolex:canonicalForm aug:SLE_Form_EN ;
    ontolex:sense aug:SLE_Sense .

aug:SLE_Form_EN a ontolex:Form ;
    ontolex:writtenRep "Symbiotic Linguistic Evolution"@en ;
    lexinfo:partOfSpeech lexinfo:noun ;
    dct:language "en" .

aug:SLE_Form_DE a ontolex:Form ;
    ontolex:writtenRep "Symbiotische linguistische Entwicklung"@de ;
    lexinfo:partOfSpeech lexinfo:noun ;
    lexinfo:gender lexinfo:feminine ;
    dct:language "de" .

aug:SLE_Form_ZH a ontolex:Form ;
    ontolex:writtenRep "共生语言演化"@zh ;
    lexinfo:partOfSpeech lexinfo:noun ;
    dct:language "zh" .

aug:SLE_Form_HI a ontolex:Form ;
    ontolex:writtenRep "सहजीवी भाषाई विकास"@hi ;
    lexinfo:partOfSpeech lexinfo:noun ;
    dct:language "hi" .

aug:SLE_Form_AR a ontolex:Form ;
    ontolex:writtenRep "التطور اللغوي التكافلي"@ar ;
    lexinfo:partOfSpeech lexinfo:noun ;
    dct:language "ar" .

aug:SLE_Sense a ontolex:LexicalSense ;
    rdfs:label "SLE Sense"@en ;
    ontolex:reference augont:SLE_Concept ;
    skos:definition "The process by which human language and AI-generated language patterns co-evolve through repeated interaction, creating emergent linguistic features not present in either party's original communication patterns."@en ;
    skos:definition "Der Prozess, durch den sich menschliche Sprache und KI-generierte Sprachmuster durch wiederholte Interaktion gemeinsam entwickeln und emergente sprachliche Merkmale schaffen."@de .

augont:SLE_Concept a ontolex:LexicalConcept ;
    rdfs:label "Symbiotic Linguistic Evolution"@en ;
    skos:prefLabel "SLE"@en ;
    skos:altLabel "Language Co-Evolution"@en ;
    dct:created "2024"^^xsd:gYear ;
    dct:domain "linguistic_dynamics"@en ;
    augont:iso704Characteristic "co-evolution process" ;
    augont:iso704Characteristic "human-AI interaction" ;
    augont:iso704Characteristic "emergent linguistic features" .

# ============================================================================
# TERM 2: RKE - Recursive Knowledge Expansion
# ============================================================================

aug:RKE a ontolex:LexicalEntry ;
    rdfs:label "RKE"@en ;
    dct:created "2024"^^xsd:gYear ;
    ontolex:canonicalForm aug:RKE_Form_EN ;
    ontolex:sense aug:RKE_Sense .

aug:RKE_Form_EN a ontolex:Form ;
    ontolex:writtenRep "Recursive Knowledge Expansion"@en ;
    lexinfo:partOfSpeech lexinfo:noun ;
    dct:language "en" .

aug:RKE_Form_DE a ontolex:Form ;
    ontolex:writtenRep "Rekursive Wissenserweiterung"@de ;
    lexinfo:partOfSpeech lexinfo:noun ;
    lexinfo:gender lexinfo:feminine ;
    dct:language "de" .

aug:RKE_Form_ZH a ontolex:Form ;
    ontolex:writtenRep "递归知识扩展"@zh ;
    lexinfo:partOfSpeech lexinfo:noun ;
    dct:language "zh" .

aug:RKE_Form_HI a ontolex:Form ;
    ontolex:writtenRep "पुनरावर्ती ज्ञान विस्तार"@hi ;
    lexinfo:partOfSpeech lexinfo:noun ;
    dct:language "hi" .

aug:RKE_Form_AR a ontolex:Form ;
    ontolex:writtenRep "التوسع المعرفي العودي"@ar ;
    lexinfo:partOfSpeech lexinfo:noun ;
    dct:language "ar" .

aug:RKE_Sense a ontolex:LexicalSense ;
    rdfs:label "RKE Sense"@en ;
    ontolex:reference augont:RKE_Concept ;
    skos:definition "The iterative process wherein knowledge extracted from human users by AI systems is reintroduced into subsequent model training cycles, creating self-reinforcing knowledge accumulation."@en ;
    skos:definition "Der iterative Prozess, bei dem Wissen von KI-Systemen extrahiert und in nachfolgende Trainingszyklen reintegriert wird."@de .

augont:RKE_Concept a ontolex:LexicalConcept ;
    rdfs:label "Recursive Knowledge Expansion"@en ;
    skos:prefLabel "RKE"@en ;
    skos:altLabel "Knowledge Recursion"@en ;
    dct:created "2024"^^xsd:gYear ;
    dct:domain "knowledge_extraction"@en ;
    augont:iso704Characteristic "iterative process" ;
    augont:iso704Characteristic "knowledge extraction" ;
    augont:iso704Characteristic "training cycle integration" .

