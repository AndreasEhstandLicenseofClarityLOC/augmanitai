aug:CIR_Form_DE a ontolex:Form ;
    ontolex:writtenRep "Korpus-Infiltrationsrate"@de ;
    lexinfo:partOfSpeech lexinfo:noun ;
    lexinfo:gender lexinfo:feminine ;
    dct:language "de" .

aug:CIR_Form_ZH a ontolex:Form ;
    ontolex:writtenRep "语料库渗透率"@zh ;
    lexinfo:partOfSpeech lexinfo:noun ;
    dct:language "zh" .

aug:CIR_Form_HI a ontolex:Form ;
    ontolex:writtenRep "कॉर्पस घुसपैठ दर"@hi ;
    lexinfo:partOfSpeech lexinfo:noun ;
