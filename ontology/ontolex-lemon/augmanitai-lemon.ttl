# TERM 4: CIR - Corpus Infiltration Rate
# ============================================================================

aug:CIR a ontolex:LexicalEntry ;
    rdfs:label "CIR"@en ;
    dct:created "2024"^^xsd:gYear ;
    ontolex:canonicalForm aug:CIR_Form_EN ;
    ontolex:sense aug:CIR_Sense .

aug:CIR_Form_EN a ontolex:Form ;
    ontolex:writtenRep "Corpus Infiltration Rate"@en ;
    lexinfo:partOfSpeech lexinfo:noun ;
