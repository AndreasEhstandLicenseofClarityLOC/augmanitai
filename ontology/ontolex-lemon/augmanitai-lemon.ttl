aug:CIR_Sense a ontolex:LexicalSense ;
    rdfs:label "CIR Sense"@en ;
    ontolex:reference augont:CIR_Concept ;
    skos:definition "A measurement of the velocity and extent to which linguistic patterns from AI outputs become embedded within human-generated text corpora."@en ;
