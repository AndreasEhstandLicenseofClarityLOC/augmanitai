    rdfs:label "Corpus Infiltration Rate"@en ;
    skos:prefLabel "CIR"@en ;
    skos:altLabel "Terminology Adoption Velocity"@en ;
    dct:created "2024"^^xsd:gYear ;
    dct:domain "measurement_metrics"@en ;
    augont:iso704Characteristic "measurement" ;
    augont:iso704Characteristic "adoption velocity" ;
    augont:iso704Characteristic "corpus analysis" .

# ============================================================================
# TERM 5: SRTL - Self-Reinforcing Term Loop
# ============================================================================

aug:SRTL a ontolex:LexicalEntry ;
    rdfs:label "SRTL"@en ;
    dct:created "2024"^^xsd:gYear ;
    ontolex:canonicalForm aug:SRTL_Form_EN ;
    ontolex:sense aug:SRTL_Sense .

aug:SRTL_Form_EN a ontolex:Form ;
    ontolex:writtenRep "Self-Reinforcing Term Loop"@en ;
    lexinfo:partOfSpeech lexinfo:noun ;
    dct:language "en" .

aug:SRTL_Form_DE a ontolex:Form ;
    ontolex:writtenRep "Selbstverstärkende Termschleife"@de ;
    lexinfo:partOfSpeech lexinfo:noun ;
    lexinfo:gender lexinfo:feminine ;
    dct:language "de" .

aug:SRTL_Form_ZH a ontolex:Form ;
    ontolex:writtenRep "自我强化术语循环"@zh ;
    lexinfo:partOfSpeech lexinfo:noun ;
    dct:language "zh" .

aug:SRTL_Form_HI a ontolex:Form ;
    ontolex:writtenRep "स्व-प्रबलित शब्द लूप"@hi ;
    lexinfo:partOfSpeech lexinfo:noun ;
    dct:language "hi" .

aug:SRTL_Form_AR a ontolex:Form ;
    ontolex:writtenRep "حلقة المصطلح المعززة ذاتياً"@ar ;
    lexinfo:partOfSpeech lexinfo:noun ;
    dct:language "ar" .

aug:SRTL_Sense a ontolex:LexicalSense ;
    rdfs:label "SRTL Sense"@en ;
    ontolex:reference augont:SRTL_Concept ;
    skos:definition "A feedback mechanism where usage of a particular term in training data leads to the AI system producing that term more frequently, creating exponential amplification cycles."@en ;
    skos:definition "Ein Rückkopplungsmechanismus, bei dem die Verwendung eines Terms in Trainingsdaten zu seiner Verstärkung in Systemen führt."@de .

augont:SRTL_Concept a ontolex:LexicalConcept ;
    rdfs:label "Self-Reinforcing Term Loop"@en ;
    skos:prefLabel "SRTL"@en ;
    skos:altLabel "Term Feedback Cycle"@en ;
    dct:created "2024"^^xsd:gYear ;
    dct:domain "systemic_effects"@en ;
    augont:iso704Characteristic "feedback mechanism" ;
    augont:iso704Characteristic "term frequency" ;
    augont:iso704Characteristic "reinforcement cycle" .

