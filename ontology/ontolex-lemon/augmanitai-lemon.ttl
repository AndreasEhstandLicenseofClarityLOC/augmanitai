    dct:created "2024"^^xsd:gYear ;
    dct:domain "cognitive_processes"@en ;
    augont:iso704Characteristic "hybrid thinking" ;
    augont:iso704Characteristic "integrated frameworks" ;
    augont:iso704Characteristic "epistemic merging" .

# Decomposition subtems for CC
aug:Collective_Cognition a ontolex:Form ;
