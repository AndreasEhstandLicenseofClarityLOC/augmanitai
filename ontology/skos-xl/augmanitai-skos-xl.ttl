# ============================================================================
# Symbiotic Linguistic Evolution (SLE)
# ============================================================================
aug:SLE skosxl:prefLabel aug:SLE_prefLabel ;
    skosxl:altLabel aug:SLE_altLabel_1, aug:SLE_altLabel_2 ;
    skosxl:hiddenLabel aug:SLE_hiddenLabel_1 .

aug:SLE_prefLabel a skosxl:Label ;
    skosxl:literalForm "Symbiotic Linguistic Evolution"@en ;
    dct:created "2024-01-15"^^xsd:date ;
    dct:creator "Andreas Ehstand" ;
    dct:language "en" ;
    rdfs:comment "Primary English designation; use for formal terminology systems"@en .

aug:SLE_altLabel_1 a skosxl:Label ;
    skosxl:literalForm "Linguistic Co-evolution"@en ;
    dct:created "2024-02-20"^^xsd:date ;
    dct:isVersionOf "Symbiotic Linguistic Evolution"@en ;
    skosxl:labelRelation aug:SLE_prefLabel ;
    rdfs:comment "Synonym emphasizing iterative co-development"@en .

aug:SLE_altLabel_2 a skosxl:Label ;
    skosxl:literalForm "Human-AI Language Interplay"@en ;
    dct:created "2024-03-10"^^xsd:date ;
    rdfs:comment "Informal variant for general audience communication"@en .

aug:SLE_hiddenLabel_1 a skosxl:Label ;
    skosxl:literalForm "Symbiotische linguistische Entwicklung"@de ;
    dct:created "2024-02-15"^^xsd:date ;
    rdfs:comment "German form for multilingual indexing; use hidden label to enable retrieval without display"@en .

