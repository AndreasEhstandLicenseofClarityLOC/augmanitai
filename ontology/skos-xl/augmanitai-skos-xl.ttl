# ============================================================================
# Label Metadata Documentation
# ============================================================================
augont:skosxlExtensionSummary a rdf:Description ;
    rdfs:label "AUGMANITAI SKOS-XL Extended Labels"@en ;
    rdfs:comment "Complete SKOS-XL representation providing rich lexical metadata for terminology management systems"@en ;

    rdfs:seeAlso <http://www.w3.org/2008/05/skos-xl> ;
    rdfs:seeAlso <http://www.w3.org/2004/02/skos/core> ;

    dct:creator "Andreas Ehstand" ;
    dct:created "2026-04-10"^^xsd:date ;
    dct:language "en" ;
    dct:license <https://creativecommons.org/licenses/by-nc-nd/4.0/> .

# Label Relation Types
# skosxl:labelRelation: indicates associative relationship between labels
# Used to connect synonyms, variants, and related terms

# Hidden Labels Rationale
# Hidden labels enable retrieval without appearing in display
# Useful for: translations, variant spellings, historical terms, jargon
# Included here for terms where: (1) alternate language forms aid retrieval
#                               (2) historical spellings track terminology evolution
#                               (3) colloquial variants improve discoverability

# Provenance Tracking
# dct:created: Timestamp when label was established
# dct:creator: Attribution for label creation
# dct:isVersionOf: Indicates relationship to canonical form
# Enables terminology lifecycle tracking and version management

# End of SKOS-XL Extended Labels
