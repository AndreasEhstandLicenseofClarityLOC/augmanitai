{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AUGMANITAI Task Definition",
  "description": "Task specifications for AUGMANITAI A2A actions",
  "definitions": {
    "termLookupTask": {
      "type": "object",
      "properties": {
        "action": {
          "const": "term_lookup"
        },
        "parameters": {
          "type": "object",
          "properties": {
            "term_id": {
              "type": "string",
              "description": "Term ID (e.g., 'sle-001') or abbreviation (e.g., 'SLE')"
            }
          },
          "required": ["term_id"],
          "additionalProperties": false
        }
      }
    },
    "termSearchTask": {
      "type": "object",
      "properties": {
        "action": {
          "const": "term_search"
        },
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query string"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 10,
              "description": "Maximum results to return"
            },
            "domainFilter": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Optional domains to filter by"
            }
          },
          "required": ["query"],
          "additionalProperties": false
        }
      }
    },
    "termRelateTask": {
      "type": "object",
      "properties": {
        "action": {
          "const": "term_relate"
        },
        "parameters": {
          "type": "object",
          "properties": {
            "term_id": {
              "type": "string",
              "description": "Term ID or abbreviation to find relations for"
            },
            "includeDefinitions": {
              "type": "boolean",
              "default": true,
              "description": "Include full definitions in related terms"
            }
          },
          "required": ["term_id"],
          "additionalProperties": false
        }
      }
    },
    "termValidateDriftTask": {
      "type": "object",
      "properties": {
        "action": {
          "const": "term_validate_drift"
        },
        "parameters": {
          "type": "object",
          "properties": {
            "term_id": {
              "type": "string",
              "description": "Term ID to validate"
            },
            "usageContext": {
              "type": "string",
              "description": "Text sample showing usage to validate against canonical definition"
            },
            "threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0.8,
              "description": "Semantic similarity threshold (0.0-1.0)"
            }
          },
          "required": ["term_id", "usageContext"],
          "additionalProperties": false
        }
      }
    },
    "listDomainsTask": {
      "type": "object",
      "properties": {
        "action": {
          "const": "list_domains"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": false
        }
      }
    }
  },
  "oneOf": [
    { "$ref": "#/definitions/termLookupTask" },
    { "$ref": "#/definitions/termSearchTask" },
    { "$ref": "#/definitions/termRelateTask" },
    { "$ref": "#/definitions/termValidateDriftTask" },
    { "$ref": "#/definitions/listDomainsTask" }
  ]
}
