{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Verifiable Credential Proof Schema",
  "description": "JSON Schema for W3C Data Integrity Proofs in AUGMANITAI credentials",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "DataIntegrityProof",
      "description": "Proof type must be DataIntegrityProof for VC 2.0"
    },
    "cryptosuite": {
      "type": "string",
      "enum": [
        "ecdsa-rdfc-2019",
        "ed25519-rdfc-2022",
        "ecdsa-2019",
        "eddsa-2022"
      ],
      "description": "Cryptographic suite identifier"
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of proof creation"
    },
    "verificationMethod": {
      "type": "string",
      "pattern": "^did:web:augmanitai.*#key",
      "description": "DID URL of the verification key used to create proof"
    },
    "proofPurpose": {
      "type": "string",
      "enum": [
        "assertionMethod",
        "authentication",
        "capabilityInvocation",
        "capabilityDelegation"
      ],
      "default": "assertionMethod",
      "description": "Purpose for which proof was created"
    },
    "proofValue": {
      "type": "string",
      "description": "Base64-encoded cryptographic signature"
    },
    "domain": {
      "type": "string",
      "description": "Optional domain restriction for proof validity"
    },
    "challenge": {
      "type": "string",
      "description": "Optional nonce for replay attack prevention"
    }
  },
  "required": [
    "type",
    "cryptosuite",
    "created",
    "verificationMethod",
    "proofValue"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "type": "DataIntegrityProof",
      "cryptosuite": "ed25519-rdfc-2022",
      "created": "2026-04-10T12:34:56Z",
      "verificationMethod": "did:web:augmanitai.local#key-1",
      "proofPurpose": "assertionMethod",
      "proofValue": "base64-encoded-signature-value-here"
    }
  ]
}
