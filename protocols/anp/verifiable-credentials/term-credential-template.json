{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AUGMANITAI Term Verifiable Credential",
  "description": "W3C Verifiable Credential v2.0 for AUGMANITAI term definitions",
  "type": "object",
  "properties": {
    "@context": {
      "type": "array",
      "items": { "type": "string" },
      "default": [
        "https://www.w3.org/ns/credentials/v2",
        "https://www.w3.org/ns/credentials/examples/v2"
      ]
    },
    "type": {
      "type": "array",
      "items": { "type": "string" },
      "default": [
        "VerifiableCredential",
        "AugmanitaiTermCredential"
      ]
    },
    "issuer": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^did:web:augmanitai"
        },
        "name": {
          "type": "string",
          "const": "AUGMANITAI"
        }
      },
      "required": ["id"]
    },
    "issuanceDate": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when credential was issued"
    },
    "expirationDate": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp when credential expires (null for non-expiring)"
    },
    "credentialSubject": {
      "type": "object",
      "description": "The term definition and metadata",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^did:web:augmanitai.*#",
          "description": "Unique identifier for this term instance"
        },
        "termId": {
          "type": "string",
          "description": "AUGMANITAI term ID (e.g., 'sle-001')"
        },
        "abbreviation": {
          "type": "string",
          "description": "Term abbreviation (e.g., 'SLE')"
        },
        "nameEn": {
          "type": "string",
          "description": "English term name"
        },
        "nameDe": {
          "type": "string",
          "description": "German term name"
        },
        "definitionEn": {
          "type": "string",
          "description": "English definition"
        },
        "definitionDe": {
          "type": "string",
          "description": "German definition"
        },
        "domain": {
          "type": "string",
          "enum": [
            "linguistic_dynamics",
            "knowledge_extraction",
            "cognitive_processes",
            "measurement_metrics",
            "systemic_effects",
            "terminological_phenomena"
          ]
        },
        "examples": {
          "type": "array",
          "items": { "type": "string" }
        },
        "isoAlignment": {
          "type": ["string", "null"]
        },
        "version": {
          "type": "string",
          "description": "Term definition version"
        },
        "status": {
          "type": "string",
          "enum": ["active", "deprecated", "archived"],
          "default": "active"
        }
      },
      "required": [
        "termId",
        "abbreviation",
        "nameEn",
        "definitionEn",
        "domain"
      ]
    },
    "proof": {
      "type": "object",
      "description": "Cryptographic proof of credential authenticity",
      "properties": {
        "type": {
          "type": "string",
          "const": "DataIntegrityProof"
        },
        "cryptosuite": {
          "type": "string",
          "enum": [
            "ecdsa-rdfc-2019",
            "ed25519-rdfc-2022",
            "ecdsa-2019"
          ]
        },
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "verificationMethod": {
          "type": "string"
        },
        "proofValue": {
          "type": "string",
          "description": "Cryptographic signature"
        }
      },
      "required": [
        "type",
        "created",
        "verificationMethod",
        "proofValue"
      ]
    }
  },
  "required": [
    "@context",
    "type",
    "issuer",
    "issuanceDate",
    "credentialSubject",
    "proof"
  ]
}
